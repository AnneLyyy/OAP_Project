{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": false,
    "outDir": ".build/frontend",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "frontend/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".build"
  ]
}
